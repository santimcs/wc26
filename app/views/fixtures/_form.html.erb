<%= form_with(model: fixture, local: true) do |form| %>
  <% if fixture.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(fixture.errors.count, "error") %> prohibited this fixture from being saved:</h2>
      <ul>
        <% fixture.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :round_id %>
    <%= form.collection_select :round_id, Round.order(:sequence), :id, :name, include_blank: true %>
  </div>

  <div class="field">
    <%= form.label :date %>
    <%= form.date_select :date, order: [:day, :month, :year] %>
  </div>

  <div class="field">
    <%= form.label :session_id %>
    <%= form.collection_select :session_id, Session.order(:sequence), :id, :time, include_blank: true %>
  </div>

  <div class="field">
    <%= form.label :home_team_id %>
    <%= form.collection_select :home_team_id, Team.order(:group, :ranking), :id, :name, include_blank: true %>
  </div>

  <div class="field">
    <%= form.label :away_team_id %>
    <%= form.collection_select :away_team_id, Team.order(:group, :ranking), :id, :name, include_blank: true %>
  </div>

  <div class="field">
    <%= form.label :channel_id %>
    <%= form.collection_select :channel_id, Channel.order(:number), :id, :name, include_blank: true %>
  </div>

  <div class="field">
    <%= form.label :criterium_id %>
    <%= form.collection_select :criterium_id, Criterium.all, :id, :show_date, include_blank: true %>
  </div>
  
  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
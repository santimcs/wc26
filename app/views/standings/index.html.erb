<% content_for :title, 'Standings' %>

<h1>🌍 World Cup 2026 Standings</h1>

<div style="margin-bottom: 20px;">
  <%= link_to "Recalculate Standings", recalculate_standings_path, method: :post, style: "background-color: #4CAF50; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;" %>
  <%= link_to "Initialize Standings", init_standings_path, method: :post, style: "background-color: #2196F3; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px; margin-left: 10px;" %>
</div>

<% if @standings.empty? %>
  <p>No standings data available. Click "Initialize Standings" to create empty standings, then add results.</p>
<% else %>
  <% @groups.sort.each do |group, standings| %>
    <h2>Group <%= group %></h2>
    
    <table id="standings_table" class="table table-striped table-hover">
      <thead>
        <tr>
          <th>Pos</th>
          <th>Team</th>
          <th>Pld</th>
          <th>W</th>
          <th>D</th>
          <th>L</th>
          <th>GF</th>
          <th>GA</th>
          <th>GD</th>
          <th>Pts</th>
          <th>Form</th>
        </tr>
      </thead>
      <tbody>
        <% standings.each_with_index do |standing, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td>
              <img src="<%= flag_url(standing.team.name) %>" width="30" height="20" style="margin-right: 8px; vertical-align: middle;" onerror="this.style.display='none'" />
              <%= standing.team.name + ' ' + standing.team.ranking.to_s %>
            </td>
            <td><%= standing.played || 0 %></td>
            <td><%= standing.wins || 0 %></td>
            <td><%= standing.draws || 0 %></td>
            <td><%= standing.losses || 0 %></td>
            <td><%= standing.goals_for || 0 %></td>
            <td><%= standing.goals_against || 0 %></td>
            <td><%= (standing.goals_for || 0) - (standing.goals_against || 0) %></td>
            <td><strong><%= standing.points || 0 %></strong></td>
            <td><%= standing.form %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <br>
  <% end %>
<% end %>

<style>
.standings-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 30px;
}

.standings-table th {
  background-color: #550065;
  color: white;
  padding: 10px;
  text-align: left;
}

.standings-table td {
  padding: 8px;
  border-bottom: 1px solid #ddd;
}

.standings-table tr:hover {
  background-color: #f5f5f5;
}
</style>


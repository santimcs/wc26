<p id="notice"><%= notice %></p>

<h1>Criteria</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Show date</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @criteria.each do |criterium| %>
      <tr>
        <td><%= criterium.show_date.strftime("%B %d, %Y") if criterium.show_date %></td>
        <td>
          <%= link_to 'Show', criterium %>
          <%= link_to 'Edit', edit_criterium_path(criterium) %>
          <%= link_to 'Destroy', criterium, method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to 'New Criterium', new_criterium_path %>
<%= form_with(model: @knockout_result, local: true) do |form| %>
  <% if @knockout_result.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@knockout_result.errors.count, "error") %> prohibited this knockout result from being saved:</h2>
      <ul>
        <% @knockout_result.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :fixture_id %>
    <%= form.collection_select :fixture_id, @fixtures, :id, ->(f) { fixture_display_with_round(f) }, include_blank: true %>
  </div>

  <div class="field">
    <%= form.label :home_goals %>
    <%= form.number_field :home_goals, min: 0 %>
  </div>

  <div class="field">
    <%= form.label :away_goals %>
    <%= form.number_field :away_goals, min: 0 %>
  </div>

  <div class="field">
    <%= form.label :home_penalties, "Home penalties (if draw)" %>
    <%= form.number_field :home_penalties, min: 0 %>
  </div>

  <div class="field">
    <%= form.label :away_penalties, "Away penalties (if draw)" %>
    <%= form.number_field :away_penalties, min: 0 %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
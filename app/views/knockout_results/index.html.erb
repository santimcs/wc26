<p id="notice"><%= notice %></p>

<h1>Knockout Results</h1>

<table>
  <thead>
    <tr>
      <th>Round</th>
      <th>Fixture</th>
      <th>Home goals</th>
      <th>Away goals</th>
      <th>Home penalties</th>
      <th>Away penalties</th>      
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @knockout_results.each do |knockout_result| %>
      <tr>
        <td><%= knockout_result.fixture.round.name %></td>
        <td><%= fixture_display_with_round(knockout_result.fixture) %></td>
        <td><%= knockout_result.home_goals %></td>
        <td><%= knockout_result.away_goals %></td>
        <td><%= knockout_result.home_penalties %></td>
        <td><%= knockout_result.away_penalties %></td>        
        <td><%= link_to 'Show', knockout_result %></td>
        <td><%= link_to 'Edit', edit_knockout_result_path(knockout_result) %></td>
        <td><%= link_to 'Destroy', knockout_result, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Knockout Result', new_knockout_result_path %>